Options -Indexes
RewriteEngine On
RewriteBase /house/

# Security: Block sensitive files
<FilesMatch "\.(htaccess|htpasswd|ini|log|sh|inc|bak|sql)$">
    Require all denied
</FilesMatch>

# 1. Custom Routes (Specific Clean URLs)
RewriteRule ^dashboard/?$ route_dashboard.php [L]
RewriteRule ^login/?$ login.php [L]
RewriteRule ^register/?$ register.php [L]
RewriteRule ^logout/?$ logout.php [L]

# 2. Generic Rule: Remove .php extension
# If the request is not a directory, and the .php file exists
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*)$ $1.php [L]

# 3. Optional: Force removal of .php in browser (Redirect)
# RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.php [NC]
# RewriteRule ^ %1 [R=301,L]
